{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OCC Secure Exports",
  "version": "0.9.3",
  "identifier": "de.occ-secure-exports.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OCC Secure Exports",
        "width": 760,
        "height": 620,
        "minWidth": 680,
        "minHeight": 515,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Retrieve & decrypt your OCC data exports.",
    "longDescription": "OCC Secure Exports lets you browse your own S3 bucket and download & decrypt your age-encrypted OCC data exports. Your private key never leaves your device.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
